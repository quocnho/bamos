#!/usr/bin/env bash
set -euo pipefail

echo "=== BamOS System Status ==="
echo ""

# OS info
if [[ -f /etc/os-release ]]; then
    . /etc/os-release
    echo "OS:       $PRETTY_NAME"
fi

# Kernel
echo "Kernel:   $(uname -r)"

# Booted image
if command -v bootc &>/dev/null; then
    bootc status --json 2>/dev/null | jq -r '
        .status.booted.image.image.image // "N/A",
        .status.booted.image.version // "N/A"
    ' 2>/dev/null | {
        read -r img; read -r ver
        echo "Image:    $img"
        echo "Version:  $ver"
    } || echo "Image:    N/A"
fi

# Disk
echo "Disk:     $(df -h / | tail -1 | awk '{print $3 \" used / \" $2 \" total\"}')"

# Updates
if command -v bootc &>/dev/null; then
    if bootc upgrade --check 2>&1 | grep -q "No changes"; then
        echo "Updates:  None (system up to date)"
    else
        echo "Updates:  Available (run 'bamos system-upgrade')"
    fi
fi
echo ""
echo "For package management:  bamos install/remove/list"
echo "For system upgrade:      bamos system-upgrade"
