#!/usr/bin/env bash
set -euo pipefail

if [[ "${#@}" -eq 0 ]]; then
    echo "Usage: bamos install <package> [package2...]"
    exit 1
fi

if [[ "$EUID" -ne 0 ]]; then
    echo "ERROR: bamos install must be run as root"
    exit 1
fi

echo "Installing packages via rpm-ostree..."
rpm-ostree install -y "$@"
echo ""
echo "Packages installed. Reboot to apply:"
echo "  systemctl reboot"
