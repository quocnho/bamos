# BamOS — passwordless sudo for wheel group

%wheel ALL=(ALL) NOPASSWD: /usr/bin/flatpak install --bundle --noninteractive -y *
%wheel ALL=(ALL) NOPASSWD: /usr/bin/flatpak install --from --noninteractive -y *
%wheel ALL=(ALL) NOPASSWD: /usr/bin/bootc status --json
%wheel ALL=(ALL) NOPASSWD: /usr/bin/bootc upgrade --check
%wheel ALL=(ALL) NOPASSWD: /usr/bin/bootc upgrade
%wheel ALL=(ALL) NOPASSWD: /usr/bin/bootc switch *
%wheel ALL=(ALL) NOPASSWD: /usr/bin/bootc rollback
%wheel ALL=(ALL) NOPASSWD: /usr/bin/bootc install *
