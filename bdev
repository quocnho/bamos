#!/usr/bin/env bash
# BamOS Dev Helper — build, test, iso, vm quickly
# Usage: ./bdev <command> [edition]
#        Editions: kde, kde-nvidia, gnome, gnome-nvidia, cosmic, cosmic-nvidia

EDITION="${2:-kde}"
DATE=$(date +%Y%m%d)

case "${1:-help}" in
    build)
        sudo bluebuild build "recipes/bamos-${EDITION}.yml"
        ;;
    test)
        podman run --rm -it "localhost/bamos-${EDITION}:latest" /bin/bash
        ;;
    iso)
        sudo bluebuild generate-iso \
            --iso-name "BamOS-${EDITION}-${DATE}.iso" \
            image "localhost/bamos-${EDITION}:latest"
        ;;
    vm)
        shift 2
        name="${1:-bamos-${EDITION}}"
        sudo virt-install \
            --name "$name" \
            --memory 4096 --vcpus 2 \
            --disk size=32 \
            --cdrom "./BamOS-${EDITION}-${DATE}.iso" \
            --os-variant fedora-unknown
        ;;
    quick)
        just "build-${EDITION}" && podman run --rm -it "localhost/bamos-${EDITION}:latest" /bin/bash
        ;;
    devloop)
        just "build-${EDITION}" && just "iso-${EDITION}"
        echo "=== Done. Run: sudo virt-install --name bamos-${EDITION} ... ==="
        ;;
    rmvm)
        sudo virsh destroy "$3" 2>/dev/null || true
        sudo virsh undefine "$3" --remove-all-storage 2>/dev/null || true
        echo "VM '$3' removed."
        ;;
    clean)
        podman images | grep bamos | awk '{print $3}' | xargs sudo podman rmi -f 2>/dev/null || true
        podman system prune -af 2>/dev/null || true
        echo "Cleaned."
        ;;
    validate)
        bluebuild validate "recipes/bamos-${EDITION}.yml"
        ;;
    *)
        echo "BamOS Dev Helper"
        echo "Usage: $0 <command> [edition]"
        echo ""
        echo "Commands:"
        echo "  build      Build image (default: kde)"
        echo "  test       Test in container"
        echo "  iso        Generate ISO"
        echo "  vm         Create VM from ISO"
        echo "  quick      Build + test container"
        echo "  devloop    Build + ISO in one go"
        echo "  rmvm       Remove VM: $0 rmvm <vm-name>"
        echo "  clean      Remove all images + cache"
        echo "  validate   Validate recipe"
        echo ""
        echo "Editions: kde, kde-nvidia, gnome, gnome-nvidia, cosmic, cosmic-nvidia"
        echo ""
        echo "Examples:"
        echo "  $0 build kde-nvidia"
        echo "  $0 quick gnome"
        echo "  $0 iso cosmic"
        echo "  $0 rmvm bamos-test"
        ;;
esac
