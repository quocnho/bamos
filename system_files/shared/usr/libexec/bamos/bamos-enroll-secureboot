#!/usr/bin/env bash
# bamos-enroll-secureboot — Enroll BamOS Secure Boot key (MOK)
# Adapted from RakuOS enroll-secureboot-key
# Queues the BamOS public key for enrollment in the Machine Owner Key (MOK) list.
# User completes enrollment via MOK Manager on next reboot.

set -euo pipefail

SB_CERT="/usr/share/bamos/secureboot/bamos-sb.der"
MOK_DIR="/var/lib/bamos/user-MOK"
MOK_KEY="${MOK_DIR}/mok.key"
MOK_PEM="${MOK_DIR}/mok.pem"
MOK_DER="${MOK_DIR}/mok.der"
ENROLLMENT_PASSWORD="bamos"

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

if [[ ! -d /sys/firmware/efi ]]; then
    echo "Hệ thống không khởi động ở chế độ EFI. Không hỗ trợ Secure Boot."
    echo "This system is not booted in EFI mode. Secure Boot enrollment is not supported."
    exit 1
fi

if [[ ! -f "$SB_CERT" ]]; then
    echo "Không tìm thấy khóa Secure Boot của BamOS tại $SB_CERT."
    echo "BamOS Secure Boot key not found at $SB_CERT."
    exit 1
fi

# Generate per-machine module signing key if not already present
if [[ ! -f "$MOK_KEY" ]]; then
    echo "Đang tạo khóa ký module cho máy..."
    echo "Generating unique per-machine module signing key..."
    mkdir -p "$MOK_DIR"
    openssl req -new -x509 -newkey rsa:2048 \
        -keyout "$MOK_KEY" -out "$MOK_PEM" \
        -days 3650 -nodes \
        -subj "/CN=BamOS Machine Module Signing Key/"
    chmod 600 "$MOK_KEY"
    openssl x509 -in "$MOK_PEM" -outform DER -out "$MOK_DER"
    echo "Đã tạo khóa ký module."
fi

enroll_cert() {
    local cert="$1"
    local label="$2"

    if LC_ALL=C mokutil -t "$cert" 2>/dev/null | grep -q "is already enrolled"; then
        echo "${label}: đã đăng ký — bỏ qua."
        return 0
    fi

    if LC_ALL=C mokutil -t "$cert" 2>/dev/null | grep -q "is already in the enrollment request"; then
        echo "${label}: đã có trong danh sách chờ đăng ký."
        return 0
    fi

    echo "Đang đăng ký ${label}..."
    echo -e "${ENROLLMENT_PASSWORD}\n${ENROLLMENT_PASSWORD}" | mokutil --import "$cert"
}

mokutil --timeout -1 || true

enroll_cert "$SB_CERT"  "Khóa Secure Boot BamOS"
enroll_cert "$MOK_DER"  "Khóa ký module máy BamOS"

echo ""
echo "Đã thêm khóa Secure Boot vào danh sách chờ đăng ký."
echo "Secure Boot key enrollment queued successfully."
echo ""
echo "Khi khởi động lại:"
echo "  1. Màn hình xanh 'MOK Manager' sẽ xuất hiện"
echo "  2. Chọn 'Enroll MOK' rồi 'Continue'"
echo "  3. Nhập mật khẩu: ${ENROLLMENT_PASSWORD}"
echo "  4. Chọn 'Reboot'"
echo ""
echo "On next reboot:"
echo "  1. A blue 'MOK Manager' screen will appear"
echo "  2. Select 'Enroll MOK' then 'Continue'"
echo "  3. Enter the password: ${ENROLLMENT_PASSWORD}"
echo "  4. Select 'Reboot'"
