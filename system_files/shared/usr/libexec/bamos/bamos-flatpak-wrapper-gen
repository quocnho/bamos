#!/usr/bin/env bash
# bamos-flatpak-wrapper-gen — Generate CLI wrappers for installed Flatpak apps
# Adapted from RakuOS flatpak-wrapper-gen
# Creates executable symlinks/wrappers in /usr/local/bin/flatpak/ so Flatpak apps
# can be launched by name from the terminal.
#
# Override file at /usr/share/bamos/flatpak-command-overrides.conf
# maps AppID=desired_command_name (one per line).

set -euo pipefail

SRC="/var/lib/flatpak/exports/bin"
DEST="/usr/local/bin/flatpak"
OVERRIDE_FILE="/usr/share/bamos/flatpak-command-overrides.conf"
TAG="# Generated by BamOS Flatpak Wrapper"

mkdir -p "$DEST"
rm -rf "$DEST"/*
declare -A OVERRIDES

# ── Load overrides file ──────────────────────────────────────────────────────
if [[ -f "$OVERRIDE_FILE" ]]; then
    while IFS='=' read -r key value; do
        [[ -z "${key// }" ]] && continue
        [[ "$key" =~ ^# ]] && continue
        OVERRIDES["$key"]="$value"
    done < "$OVERRIDE_FILE"
fi

# ── Generate wrappers ───────────────────────────────────────────────────────
[[ -d "$SRC" ]] || exit 0

for export in "$SRC"/*; do
    [[ -f "$export" ]] || continue

    app_id=$(basename "$export")

    # Use override if present, otherwise derive command name from last segment
    if [[ -n "${OVERRIDES[$app_id]:-}" ]]; then
        cmd_name="${OVERRIDES[$app_id]}"
    else
        cmd_name=$(echo "$app_id" | awk -F. '{print tolower($NF)}')
    fi

    wrapper="$DEST/$cmd_name"

    # Do not override real system binaries
    if command -v "$cmd_name" >/dev/null 2>&1; then
        real_path=$(command -v "$cmd_name")
        if [[ "$real_path" != "$wrapper" ]]; then
            continue
        fi
    fi

    cat > "$wrapper" <<EOF
#!/usr/bin/env bash
$TAG
exec flatpak run "$app_id" "\$@"
EOF

    chmod +x "$wrapper"
done

echo "bamos-flatpak-wrapper-gen: $(ls "$DEST" 2>/dev/null | wc -l) CLI wrappers generated."
