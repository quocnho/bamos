# Auto detect text files and perform LF normalization
* text=auto

# Containerfile
Containerfile text eol=lf

# Shell scripts
*.sh text eol=lf

# YAML configs
*.yml text eol=lf
*.yaml text eol=lf

# Justfile
Justfile text eol=lf

# Documentation
*.md text eol=lf

# SVG/XML
*.svg text eol=lf
*.xml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
